# ============================================================
# SERVIX Backend — Environment Variables Example
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com dados reais
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3000
APP_NAME=SERVIX
API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:19000,http://localhost:19006

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://servix:servix123@localhost:5432/servix_dev

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Apple Sign In
APPLE_TEAM_ID=placeholder
APPLE_KEY_ID=placeholder
APPLE_PRIVATE_KEY=placeholder

# ============================================================
# PAYMENTS — MercadoPago (Brasil / LatAm)
# ============================================================
MERCADOPAGO_ACCESS_TOKEN=placeholder
MERCADOPAGO_PUBLIC_KEY=placeholder
MERCADOPAGO_WEBHOOK_SECRET=placeholder

# ============================================================
# PAYMENTS — Stripe (Internacional)
# ============================================================
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Default gateway per country
DEFAULT_PAYMENT_GATEWAY=MERCADOPAGO

# ============================================================
# NOTIFICATIONS
# ============================================================
# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=placeholder
FIREBASE_PRIVATE_KEY=placeholder
FIREBASE_CLIENT_EMAIL=placeholder@project.iam.gserviceaccount.com

# Twilio SMS
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_FROM_NUMBER=+15005550006

# ============================================================
# EMAIL (SMTP)
# ============================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@servix.app

# ============================================================
# STORAGE (S3 / MinIO)
# ============================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=servix
S3_SECRET_ACCESS_KEY=servix12345
S3_BUCKET_DOCUMENTS=servix-documents
S3_BUCKET_AVATARS=servix-avatars
S3_BUCKET_PUBLIC=servix-public
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ============================================================
# MAPS
# ============================================================
GOOGLE_MAPS_API_KEY=placeholder
MAPBOX_ACCESS_TOKEN=placeholder

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================================
# FEATURE FLAGS (Runtime overrides — prefer DB flags)
# ============================================================
ENABLE_SWAGGER=true
ENABLE_MOCK_PAYMENTS=true
ENABLE_DEBUG_LOGS=true
