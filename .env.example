# =============================================================================
# ENVIRONMENT VARIABLES — copie para .env e preencha os valores
# =============================================================================

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/servicos_dev?schema=public"
DATABASE_TEST_URL="postgresql://postgres:postgres@localhost:5432/servicos_test?schema=public"

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
API_VERSION="v1"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-at-least-64-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── FRONTEND ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── PAYMENTS ────────────────────────────────────────────────────────────────
# Asaas (pagamento BR)
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"

# PagSeguro (fallback)
PAGSEGURO_TOKEN=""
PAGSEGURO_APP_ID=""
PAGSEGURO_APP_KEY=""

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
# WhatsApp Business API (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# SendGrid (Email)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@seudominio.com.br"

# ─── STORAGE ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="sa-east-1"
AWS_S3_BUCKET="servicos-uploads-dev"
AWS_CLOUDFRONT_URL=""

# ─── AUTH / OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── IDENTITY VERIFICATION ───────────────────────────────────────────────────
# Unico.io (verificação biométrica)
UNICO_CLIENT_ID=""
UNICO_CLIENT_SECRET=""

# Serasa (checagem de antecedentes)
SERASA_API_KEY=""

# ─── MONITORING ──────────────────────────────────────────────────────────────
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ─── ML / AI ─────────────────────────────────────────────────────────────────
ML_SERVICE_URL="http://localhost:8000"
ML_SERVICE_API_KEY=""
OPENAI_API_KEY=""

# ─── GEOLOCATION ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=""
