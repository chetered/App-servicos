// =============================================================================
// PRISMA SCHEMA — MARKETPLACE DE SERVIÇOS
// Production-grade schema for a services marketplace app
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), postgis]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION

  @@map("user_status")
}

enum OtpChannel {
  EMAIL
  SMS
  WHATSAPP

  @@map("otp_channel")
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
  PHONE_VERIFICATION
  EMAIL_VERIFICATION
  PAYMENT_CONFIRMATION

  @@map("otp_purpose")
}

enum AuthProviderType {
  GOOGLE
  FACEBOOK
  APPLE
  PHONE

  @@map("auth_provider_type")
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB

  @@map("device_platform")
}

enum BlockedIdentityType {
  EMAIL
  PHONE
  IP_ADDRESS
  DEVICE_FINGERPRINT

  @@map("blocked_identity_type")
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING
  DATA_PROCESSING
  COOKIES

  @@map("consent_type")
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY

  @@map("gender")
}

enum AddressType {
  HOME
  WORK
  OTHER

  @@map("address_type")
}

enum VerificationStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED

  @@map("verification_status")
}

enum DocumentType {
  CPF
  RG
  CNH
  PASSPORT
  SELFIE
  PROOF_OF_ADDRESS
  PROFESSIONAL_LICENSE

  @@map("document_type")
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED

  @@map("service_status")
}

enum PricingType {
  FIXED
  HOURLY
  CUSTOM_QUOTE

  @@map("pricing_type")
}

enum BookingStatus {
  PENDING_PAYMENT
  PAYMENT_AUTHORIZED
  CONFIRMED
  PROVIDER_EN_ROUTE
  IN_PROGRESS
  COMPLETED
  CANCELLED_CLIENT
  CANCELLED_PROVIDER
  CANCELLED_SYSTEM
  DISPUTED
  REFUNDED

  @@map("booking_status")
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CHARGEBACK

  @@map("payment_status")
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
  WALLET

  @@map("payment_method")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED

  @@map("payout_status")
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REMOVED

  @@map("review_status")
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CLIENT
  RESOLVED_PROVIDER
  ESCALATED
  CLOSED

  @@map("dispute_status")
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  WHATSAPP
  IN_APP

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED

  @@map("notification_status")
}

enum RecurrenceFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY

  @@map("recurrence_frequency")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
}

enum CampaignType {
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  FREE_SERVICE
  CASHBACK
  REFERRAL_BONUS

  @@map("campaign_type")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  CANCELLED

  @@map("campaign_status")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED

  @@map("support_ticket_status")
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("support_ticket_priority")
}

enum SubscriptionPlan {
  FREE
  BASIC
  PROFESSIONAL
  PREMIUM

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  EXPIRED

  @@map("subscription_status")
}

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED

  @@map("commission_type")
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  REFUND
  PAYOUT
  BONUS
  ADJUSTMENT

  @@map("wallet_transaction_type")
}

enum AbTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED

  @@map("ab_test_status")
}

enum WebhookStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING

  @@map("webhook_status")
}

enum FlagType {
  INAPPROPRIATE_CONTENT
  FRAUD
  SPAM
  SAFETY_CONCERN
  OTHER

  @@map("flag_type")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
  SUSPEND
  RESTORE

  @@map("audit_action")
}

// =============================================================================
// IDENTITY & ACCESS (MVP)
// =============================================================================

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String?   @unique
  phone               String?   @unique
  password_hash       String?
  status              UserStatus @default(PENDING_VERIFICATION)
  email_verified_at   DateTime?
  phone_verified_at   DateTime?
  last_login_at       DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  // Relations
  roles               UserRole[]
  sessions            UserSession[]
  refresh_tokens      RefreshToken[]
  otp_codes           OtpCode[]
  auth_providers      AuthProvider[]
  devices             Device[]
  consents            UserConsent[]
  security_events     SecurityEvent[]
  profile             UserProfile?
  preferences         UserPreference?
  addresses           UserAddress[]
  provider_profile    ProviderProfile?
  saved_providers     SavedProvider[]
  bookings_as_client  Booking[]        @relation("ClientBookings")
  reviews_given       Review[]         @relation("ClientReviews")
  reviews_received    Review[]         @relation("ProviderReviews")
  notifications       Notification[]
  support_tickets     SupportTicket[]
  wallet              Wallet?
  referrals_made      Referral[]       @relation("ReferrerUser")
  referral_received   Referral?        @relation("ReferredUser")
  flags_reported      ContentFlag[]    @relation("FlagReporter")
  audit_logs          AuditLog[]
  chat_messages       ChatMessage[]
  ab_test_assignments AbTestAssignment[]
  coupon_usages       CouponUsage[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([created_at])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  is_system   Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user_roles  UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  resource    String
  action      String
  description String?
  created_at  DateTime @default(now())

  role_permissions RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model UserRole {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  role_id    String    @db.Uuid
  granted_by String?   @db.Uuid
  granted_at DateTime  @default(now())
  expires_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id])
  @@index([user_id])
  @@map("user_roles")
}

model RolePermission {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String   @db.Uuid
  permission_id String   @db.Uuid
  created_at    DateTime @default(now())

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model UserSession {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique
  device_id   String?   @db.Uuid
  ip_address  String?
  user_agent  String?
  expires_at  DateTime
  revoked_at  DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@index([expires_at])
  @@map("user_sessions")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique
  device_id   String?   @db.Uuid
  expires_at  DateTime
  used_at     DateTime?
  revoked_at  DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model OtpCode {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?    @db.Uuid
  channel     OtpChannel
  code_hash   String
  purpose     OtpPurpose
  expires_at  DateTime
  verified_at DateTime?
  attempts    Int        @default(0)
  created_at  DateTime   @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, purpose])
  @@index([expires_at])
  @@map("otp_codes")
}

model AuthProvider {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String           @db.Uuid
  provider                 AuthProviderType
  provider_user_id         String
  access_token_encrypted   String?
  refresh_token_encrypted  String?
  token_expires_at         DateTime?
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@index([user_id])
  @@map("auth_providers")
}

model Device {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String         @db.Uuid
  fingerprint  String?
  platform     DevicePlatform
  push_token   String?
  app_version  String?
  os_version   String?
  is_trusted   Boolean        @default(false)
  last_seen_at DateTime?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([fingerprint])
  @@map("devices")
}

model LoginAttempt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier     String
  ip_address     String?
  user_agent     String?
  success        Boolean
  failure_reason String?
  created_at     DateTime @default(now())

  @@index([identifier])
  @@index([ip_address])
  @@index([created_at])
  @@map("login_attempts")
}

model BlockedIdentity {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type       BlockedIdentityType
  value      String
  reason     String?
  blocked_by String?             @db.Uuid
  expires_at DateTime?
  created_at DateTime            @default(now())

  @@unique([type, value])
  @@index([type, value])
  @@map("blocked_identities")
}

model SecurityEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  event_type String
  ip_address String?
  device_id  String?  @db.Uuid
  metadata   Json?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([event_type])
  @@index([created_at])
  @@map("security_events")
}

model UserConsent {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String      @db.Uuid
  consent_type ConsentType
  version      String
  accepted     Boolean
  ip_address   String?
  accepted_at  DateTime?
  created_at   DateTime    @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, consent_type])
  @@map("user_consents")
}

// =============================================================================
// USER PROFILE (MVP)
// =============================================================================

model UserProfile {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @unique @db.Uuid
  first_name   String?
  last_name    String?
  display_name String?
  avatar_url   String?
  bio          String?
  birth_date   DateTime?
  gender       Gender?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserPreference {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String   @unique @db.Uuid
  notification_push      Boolean  @default(true)
  notification_email     Boolean  @default(true)
  notification_sms       Boolean  @default(false)
  notification_whatsapp  Boolean  @default(true)
  language               String   @default("pt-BR")
  currency               String   @default("BRL")
  timezone               String   @default("America/Sao_Paulo")
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserAddress {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String      @db.Uuid
  type         AddressType @default(HOME)
  label        String?
  street       String
  number       String?
  complement   String?
  neighborhood String?
  city         String
  state        String
  country      String      @default("BR")
  postal_code  String
  latitude     Float?
  longitude    Float?
  is_default   Boolean     @default(false)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  deleted_at   DateTime?

  user     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([user_id])
  @@index([postal_code])
  @@map("user_addresses")
}

// =============================================================================
// PROVIDER PROFILE (MVP)
// =============================================================================

model ProviderProfile {
  id                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String             @unique @db.Uuid
  business_name            String?
  cpf_cnpj                 String?
  bio                      String?
  years_experience         Int?
  website_url              String?
  service_radius_km        Float              @default(10.0)
  is_available             Boolean            @default(false)
  verification_status      VerificationStatus @default(PENDING)
  verified_at              DateTime?
  overall_rating           Float              @default(0)
  total_reviews            Int                @default(0)
  total_completions        Int                @default(0)
  completion_rate          Float              @default(0)
  acceptance_rate          Float              @default(0)
  response_time_minutes    Int?
  subscription_plan        SubscriptionPlan   @default(FREE)
  subscription_expires_at  DateTime?
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt
  deleted_at               DateTime?

  user                  User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  categories            ProviderCategory[]
  services              ProviderService[]
  availability_slots    ProviderAvailability[]
  verification_docs     ProviderDocument[]
  bookings              Booking[]              @relation("ProviderBookings")
  location_history      ProviderLocation[]
  subscriptions         ProviderSubscription[]
  bank_accounts         ProviderBankAccount[]
  commissions           Commission[]
  payouts               Payout[]
  saved_by              SavedProvider[]

  @@index([verification_status])
  @@index([is_available])
  @@index([overall_rating])
  @@map("provider_profiles")
}

model ProviderDocument {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String             @db.Uuid
  type        DocumentType
  file_url    String
  file_key    String
  status      VerificationStatus @default(PENDING)
  reviewed_by String?            @db.Uuid
  reviewed_at DateTime?
  notes       String?
  expires_at  DateTime?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id, type])
  @@map("provider_documents")
}

model ProviderLocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String   @db.Uuid
  latitude    Float
  longitude   Float
  accuracy    Float?
  heading     Float?
  speed       Float?
  recorded_at DateTime @default(now())

  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@index([provider_id, recorded_at])
  @@map("provider_locations")
}

model ProviderAvailability {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id  String    @db.Uuid
  day_of_week  DayOfWeek
  start_time   String
  end_time     String
  is_available Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, day_of_week, start_time])
  @@index([provider_id])
  @@map("provider_availability")
}

model ProviderSubscription {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String             @db.Uuid
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  price_cents Int
  currency    String             @default("BRL")
  starts_at   DateTime
  expires_at  DateTime
  cancelled_at DateTime?
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt

  provider       ProviderProfile  @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  payment        Payment?

  @@index([provider_id])
  @@index([status, expires_at])
  @@map("provider_subscriptions")
}

model ProviderBankAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id    String   @db.Uuid
  bank_code      String
  agency         String
  account_number String
  account_type   String
  pix_key        String?
  is_default     Boolean  @default(false)
  verified_at    DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  payouts  Payout[]

  @@index([provider_id])
  @@map("provider_bank_accounts")
}

// =============================================================================
// SERVICE CATALOG (MVP)
// =============================================================================

model Category {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id        String?   @db.Uuid
  name             String
  slug             String    @unique
  description      String?
  icon_url         String?
  image_url        String?
  is_active        Boolean   @default(true)
  sort_order       Int       @default(0)
  commission_rate  Float     @default(0.20)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  parent   Category?          @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children Category[]         @relation("CategoryHierarchy")
  providers ProviderCategory[]
  services  ProviderService[]
  search_index CategorySearchIndex?

  @@index([parent_id])
  @@index([slug])
  @@map("categories")
}

model CategorySearchIndex {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String   @unique @db.Uuid
  keywords    String[]
  synonyms    String[]
  updated_at  DateTime @updatedAt

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@map("category_search_index")
}

model ProviderCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id String   @db.Uuid
  category_id String   @db.Uuid
  is_primary  Boolean  @default(false)
  created_at  DateTime @default(now())

  provider ProviderProfile @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  category Category        @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, category_id])
  @@map("provider_categories")
}

model ProviderService {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String        @db.Uuid
  category_id       String        @db.Uuid
  name              String
  description       String?
  status            ServiceStatus @default(DRAFT)
  pricing_type      PricingType   @default(FIXED)
  price_cents       Int?
  price_min_cents   Int?
  price_max_cents   Int?
  duration_minutes  Int?
  images            String[]
  tags              String[]
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  deleted_at        DateTime?

  provider ProviderProfile   @relation(fields: [provider_id], references: [id], onDelete: Cascade)
  category Category          @relation(fields: [category_id], references: [id])
  bookings Booking[]

  @@index([provider_id])
  @@index([category_id])
  @@index([status])
  @@map("provider_services")
}

// =============================================================================
// BOOKING & SCHEDULING (MVP)
// =============================================================================

model Booking {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id           String        @db.Uuid
  provider_id         String        @db.Uuid
  service_id          String        @db.Uuid
  address_id          String?       @db.Uuid
  status              BookingStatus @default(PENDING_PAYMENT)
  scheduled_at        DateTime
  estimated_duration  Int?
  actual_start_at     DateTime?
  actual_end_at       DateTime?
  notes               String?
  cancellation_reason String?
  cancelled_by        String?       @db.Uuid
  subtotal_cents      Int
  discount_cents      Int           @default(0)
  service_fee_cents   Int           @default(0)
  total_cents         Int
  recurrence_id       String?       @db.Uuid
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  client     User            @relation("ClientBookings", fields: [client_id], references: [id])
  provider   ProviderProfile @relation("ProviderBookings", fields: [provider_id], references: [id])
  service    ProviderService @relation(fields: [service_id], references: [id])
  address    UserAddress?    @relation(fields: [address_id], references: [id])
  recurrence RecurringBooking? @relation(fields: [recurrence_id], references: [id])
  payments   Payment[]
  reviews    Review[]
  disputes   Dispute[]
  commissions Commission[]
  timeline   BookingTimeline[]
  tracking   BookingTracking[]
  chat_room  ChatRoom?

  @@index([client_id])
  @@index([provider_id])
  @@index([status])
  @@index([scheduled_at])
  @@map("bookings")
}

model BookingTimeline {
