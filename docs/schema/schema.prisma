// =============================================================================
// PROMOTIONS & CAMPAIGNS
// =============================================================================

model Campaign {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  description  String?
  type         CampaignType
  status       CampaignStatus @default(DRAFT)
  discount_percent Float?
  discount_fixed_cents Int?
  min_order_cents Int?
  max_discount_cents Int?
  budget_cents Int?
  spent_cents  Int            @default(0)
  starts_at    DateTime
  ends_at      DateTime?
  created_by   String         @db.Uuid
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  coupons Coupon[]

  @@index([status])
  @@index([starts_at, ends_at])
  @@map("campaigns")
}

model Coupon {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id     String?        @db.Uuid
  code            String         @unique
  description     String?
  type            CampaignType
  discount_percent Float?
  discount_fixed_cents Int?
  min_order_cents Int?
  max_discount_cents Int?
  max_uses        Int?
  uses_per_user   Int            @default(1)
  times_used      Int            @default(0)
  starts_at       DateTime
  ends_at         DateTime?
  is_active       Boolean        @default(true)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  campaign Campaign?     @relation(fields: [campaign_id], references: [id])
  usages   CouponUsage[]

  @@index([code])
  @@index([is_active, starts_at, ends_at])
  @@map("coupons")
}

model CouponUsage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coupon_id   String   @db.Uuid
  user_id     String   @db.Uuid
  booking_id  String?  @db.Uuid
  discount_applied_cents Int
  used_at     DateTime @default(now())

  coupon  Coupon @relation(fields: [coupon_id], references: [id])
  user    User   @relation(fields: [user_id], references: [id])

  @@unique([coupon_id, user_id, booking_id])
  @@index([user_id])
  @@map("coupon_usages")
}

model Referral {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrer_id     String   @db.Uuid
  referred_id     String   @unique @db.Uuid
  referral_code   String
  reward_cents    Int      @default(0)
  reward_paid     Boolean  @default(false)
  reward_paid_at  DateTime?
  created_at      DateTime @default(now())

  referrer User @relation("ReferrerUser", fields: [referrer_id], references: [id])
  referred User @relation("ReferredUser", fields: [referred_id], references: [id])

  @@index([referrer_id])
  @@index([referral_code])
  @@map("referrals")
}

