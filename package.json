{
  "name": "servicos-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace de serviços — monorepo NestJS + Prisma + Next.js + React Native",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@servicos/api",
    "dev:web": "turbo run dev --filter=@servicos/web",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@servicos/database",
    "db:migrate": "turbo run db:migrate --filter=@servicos/database",
    "db:studio": "turbo run db:studio --filter=@servicos/database",
    "db:seed": "turbo run db:seed --filter=@servicos/database",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@10.29.3"
}
